name: PR SAST Security Scan  # 워크플로우 이름(깃헙 Actions 화면에 표시)

on:  # 워크플로우 트리거 조건
  pull_request:  # PR 생성/업데이트 시 실행
    branches:
      - main  # main 브랜치로 들어오는 PR만 대상
      #- develop  # (주석) develop도 대상 가능
      # 테스트 단계라서 push test/sast pr할 때로 변경하기  # 테스트용 브랜치 운영 메모
  push:  # 특정 브랜치로 push 시에도 실행
    branches:
	    - test/sast_pr  # 테스트용 브랜치에 푸시되면 실행
  workflow_dispatch:  # 수동 실행(버튼으로 실행)
    inputs:
      pr_number:  # 수동 실행 시 스캔할 PR 번호 입력
        description: 'PR number to scan'  # 입력값 설명
        required: true  # 필수 입력
        type: string  # 문자열로 받음

# PR당 하나의 SAST 워크플로우만 실행  # 같은 PR에서 중복 실행 방지(동시성 제어)
concurrency:
  group: pr-sast-${{ github.event.pull_request.number || github.event.inputs.pr_number }}  # PR번호 기준으로 그룹 묶기(수동 실행도 지원)
  cancel-in-progress: true  # 같은 그룹에서 새 실행이 뜨면 기존 실행 취소(최신만 유지)

permissions:  # 워크플로우가 GitHub API/리포지토리에 접근할 권한
  contents: read  # 레포 코드 읽기 권한(체크아웃/분석에 필요)
  pull-requests: write  # PR에 코멘트 작성 권한(결과 요약 댓글)
  security-events: write  # 보안 이벤트(예: SARIF 업로드)에 필요한 권한(현재는 upload:false지만 확장 대비)
  checks: write  # GitHub Check 생성 권한(SG verdict를 체크로 표시)
jobs:  # 실제 실행될 작업(Job)들
  # ===================================================================
  # Job 1: SonarQube 분석
  # ===================================================================
  sonarqube:
    name: SonarQube Analysis  # Job 표시 이름
    runs-on: ubuntu-latest  # 실행 러너(OS)

    steps:
      - name: Checkout code  # 소스코드 가져오기
        uses: actions/checkout@v4  # 깃헙 공식 체크아웃 액션
        with:
          fetch-depth: 0  # SonarQube가 blame/히스토리 기반 분석을 하려면 전체 히스토리가 유리함(얕은 clone 방지)

      - name: Setup Node.js  # Node 환경 준비(프론트/TS/JS 분석 빌드용)
        uses: actions/setup-node@v4  # Node 설치 액션
        with:
          node-version: '20'  # Node 20 사용

      - name: Setup pnpm  # pnpm 패키지 매니저 설치
        uses: pnpm/action-setup@v2  # pnpm 설치 액션
        with:
          version: 8.15.4  # pnpm 버전 고정(재현성)

      - name: Install dependencies  # 의존성 설치(빌드/분석에 필요)
        run: pnpm install --no-frozen-lockfile  # lockfile 고정 강제 안 함(환경/lock mismatch 허용)

      - name: Run SonarQube Scanner  # SonarQube 정적 분석 실행
        uses: sonarsource/sonarqube-scan-action@master  # SonarQube 스캔 액션(브랜치/PR 분석 가능)
        env:
          SONAR_TOKEN: ${{ secrets.SONAR_TOKEN }}  # Sonar 인증 토큰(시크릿)
          SONAR_HOST_URL: ${{ secrets.SONAR_HOST_URL }}  # Sonar 서버 주소(시크릿)

      - name: Download SonarQube results  # SonarQube 이슈 결과를 API로 내려받아 파일로 저장
        run: |
          mkdir -p scan-results  # 결과 저장 폴더 생성
          # SonarQube API를 통해 분석 결과 다운로드
          curl -u "${{ secrets.SONAR_TOKEN }}:" \  # 토큰 기반 Basic auth(비밀번호 빈 값 형태)
            "${{ secrets.SONAR_HOST_URL }}/api/issues/search?componentKeys=${{ secrets.SONAR_PROJECT_KEY }}&resolved=false" \  # 미해결 이슈 조회
            -o scan-results/sonar-results.json  # 결과를 JSON으로 저장. scan-results/sonar-results.json 

      - name: Upload SonarQube results  # Sonar 결과 JSON을 아티팩트로 업로드(다른 Job에서 사용)
        uses: actions/upload-artifact@v4
        with:
          name: sonar-results  # 아티팩트 이름
          path: scan-results/sonar-results.json  # 업로드할 파일 경로
          retention-days: 7  # 보관 기간(일)
# ===================================================================
  # Job 2: Semgrep 분석
  # ===================================================================
  semgrep:
    name: Semgrep Analysis  # Job 표시 이름
    runs-on: ubuntu-latest  # 실행 러너

    steps:
      - name: Checkout code  # 소스코드 가져오기
        uses: actions/checkout@v4

      - name: Run Semgrep  # Semgrep 규칙팩으로 SAST 수행
        uses: semgrep/semgrep-action@v1  # Semgrep 공식 액션
        with:
          config: >-  # 사용할 룰셋(Semgrep Registry에 있는 프리셋들)
            p/security-audit  # 일반 보안 이슈 점검
            p/owasp-top-ten  # OWASP Top 10 기반 룰
            p/javascript  # JS 룰
            p/typescript  # TS 룰
            p/react  # React 패턴/보안 룰
          generateSarif: "1"  # 분석 결과를 SARIF 포맷으로도 생성 
        env:
          SEMGREP_APP_TOKEN: ${{ secrets.SEMGREP_APP_TOKEN }}  # Semgrep Cloud/인증 토큰(필요 시). 로컬 룰만 스면 없어도 동작하는 경우 많음 

      - name: Convert SARIF to JSON  # Semgrep 결과를 JSON으로도 따로 생성(LLM/리포트 입력용)
        run: |
          mkdir -p scan-results  # 결과 저장 폴더 생성
          # Semgrep은 기본적으로 JSON 출력도 제공
          semgrep --config "p/security-audit" \  # 동일 룰셋 지정(액션과 일치)
            --config "p/owasp-top-ten" \
            --config "p/javascript" \
            --config "p/typescript" \
            --config "p/react" \
            --json -o scan-results/semgrep-results.json  # JSON 출력 저장

      - name: Upload Semgrep results  # Semgrep JSON 결과를 아티팩트로 업로드
        uses: actions/upload-artifact@v4
        with:
          name: semgrep-results  # 아티팩트 이름
          path: scan-results/semgrep-results.json  # 업로드 대상
          retention-days: 7  # 보관 기간
# ===================================================================
# Job 3: CodeQL 분석
# ===================================================================
codeql:
  name: CodeQL Analysis                     # ▶ CodeQL 정적 분석 Job
  runs-on: ubuntu-latest                   # ▶ GitHub 기본 Ubuntu 러너 사용

  # ▶ 같은 Job을 언어별로 반복 실행
  # ▶ CodeQL은 언어마다 별도의 분석 DB를 만들기 때문에 분리 실행이 정석
  strategy:
    matrix:
      language: [ 'javascript', 'typescript', 'java-kotlin' ]

  steps:
    - name: Checkout code
      uses: actions/checkout@v4             # ▶ 분석 대상 소스코드 체크아웃

    - name: Initialize CodeQL
      uses: github/codeql-action/init@v3    # ▶ CodeQL 초기화 (DB 생성 + 쿼리 설정)
      with:
        languages: ${{ matrix.language }}   # ▶ 현재 matrix 언어
        queries: security-extended,security-and-quality
                                            # ▶ 보안 위주 + 보안/품질 혼합 쿼리

    # ===============================================================
    # Java / Kotlin 전용 설정
    # ===============================================================

    - name: Setup JDK (Java/Kotlin only)
      if: matrix.language == 'java-kotlin'  # ▶ Java/Kotlin일 때만 실행
      uses: actions/setup-java@v4
      with:
        distribution: 'temurin'             # ▶ OpenJDK 배포판
        java-version: '21'                  # ▶ 검토 기준 JDK 21
                                            # ▶ (17로 두면 21 프로젝트에서 빌드 깨질 수 있음)

    - name: Build (Java/Kotlin only)
      if: matrix.language == 'java-kotlin'  # ▶ Java/Kotlin일 때만 직접 빌드
      shell: bash
      run: |
        set -euo pipefail

        echo "🔎 Detecting Java build tool..."

        if [ -f "./gradlew" ]; then
          echo "Gradle wrapper detected"
          chmod +x ./gradlew
          ./gradlew clean build -x test

        elif [ -f "./mvnw" ]; then
          echo "Maven wrapper detected"
          chmod +x ./mvnw
          ./mvnw -B -DskipTests package

        elif [ -f "pom.xml" ]; then
          echo "pom.xml detected (system mvn)"
          mvn -B -DskipTests package


        else
          echo "No Java build tool found (gradlew / mvnw / pom.xml)"
          exit 1
        fi

    # ===============================================================
    # JS / TS 전용 설정
    # ===============================================================

    - name: Autobuild (JS/TS only)
      if: matrix.language != 'java-kotlin'  # ▶ JS/TS만 autobuild 사용
      uses: github/codeql-action/autobuild@v3
                                            # ▶ JS/TS는 대부분 자동 빌드로 충분
                                            # ▶ Java/C++은 여기서 자주 깨지므로 제외

    # ===============================================================
    # CodeQL 분석 실행
    # ===============================================================

    - name: Perform CodeQL Analysis
      uses: github/codeql-action/analyze@v3 # ▶ 실제 CodeQL 분석 수행
      with:
        category: "/language:${{ matrix.language }}"
                                            # ▶ 결과에 언어 태그 부여
        output: scan-results/codeql-${{ matrix.language }}.sarif
                                            # ▶ 언어별 SARIF 파일 생성
        upload: false                        # ▶ GitHub Security 탭 자동 업로드 비활성화
                                            # ▶ (우리는 Claude 요약 + SG 연계 사용)

    - name: Upload CodeQL results
      uses: actions/upload-artifact@v4      # ▶ 다음 Job에서 쓰기 위해 아티팩트로 업로드
      with:
        name: codeql-${{ matrix.language }}-results
                                            # ▶ 언어별 아티팩트 이름
        path: scan-results/codeql-${{ matrix.language }}.sarif
                                            # ▶ 업로드 대상 SARIF
        retention-days: 7                   # ▶ 단기 보관


  # ===================================================================
  # Job 4: 결과 통합 및 Claude 분석
  # ===================================================================
  analyze-and-report:
    name: AI Analysis & Report  # Job 표시 이름(LLM으로 리포트 생성)
    runs-on: ubuntu-latest  # 실행 러너
    needs: [sonarqube, semgrep, codeql]  # 앞선 스캔 Job들이 끝나야 실행

    steps:
      - name: Checkout code  # 리포트 생성 스크립트/템플릿을 위해 코드 체크아웃
        uses: actions/checkout@v4

      - name: Download all scan results  # 이전 Job들의 아티팩트를 전부 다운로드
        uses: actions/download-artifact@v4
        with:
          path: scan-results  # 아티팩트들을 이 폴더 아래에 풀어놓음

      - name: Merge CodeQL results  # JS/TS CodeQL SARIF를 하나로 합쳐 단일 입력으로 만듦
        run: |
          # CodeQL 결과 병합 (여러 언어의 SARIF 파일을 하나로)
          python3 -c "  # 원라이너 파이썬으로 병합 수행
          import json
          import glob

          sarif_files = glob.glob('scan-results/codeql-*-results/*.sarif')  # 다운로드된 아티팩트 경로에서 sarif 수집
          merged = {'runs': []}  # SARIF 구조에서 runs만 합칠 것

          for f in sarif_files:
              with open(f) as file:
                  data = json.load(file)
                  merged['runs'].extend(data.get('runs', []))  # 각 SARIF의 runs를 누적

          with open('scan-results/codeql-results.sarif', 'w') as out:
              json.dump(merged, out, indent=2)  # 병합 결과를 새 파일로 저장
          "

      - name: Reorganize results  # 다운로드된 아티팩트 폴더 구조를 단일 디렉토리로 정리
        run: |
          # 아티팩트 구조 정리
          mv scan-results/sonar-results/sonar-results.json scan-results/ || true  # sonar 아티팩트 파일을 루트로 이동(없어도 실패 안 함)
          mv scan-results/semgrep-results/semgrep-results.json scan-results/ || true  # semgrep 아티팩트 파일을 루트로 이동
          ls -la scan-results/  # 결과 파일 목록 확인(디버깅)

      - name: Setup Python  # LLM 분석 스크립트 실행을 위한 파이썬 설치
        uses: actions/setup-python@v5
        with:
          python-version: '3.11'  # 파이썬 3.11 사용

      - name: Install Python dependencies  # LangChain(Anthropic 연동) 의존성 설치
        run: |
          pip install langchain-anthropic langchain-core  # Claude 호출용 라이브러리 설치

      - name: Run Claude AI Analysis  # Sonar/Semgrep/CodeQL 결과를 Claude로 요약/분석해 리포트 생성
        env:
          ANTHROPIC_API_KEY: ${{ secrets.ANTHROPIC_API_KEY }}  # Anthropic API 키(시크릿)
        run: |
          chmod +x .github/scripts/llm-analyzer.py  # 스크립트 실행권한 부여(필요 시)
          python3 .github/scripts/llm-analyzer.py scan-results  # scan-results 폴더를 입력으로 리포트 생성

      - name: Upload final report  # 최종 리포트를 아티팩트로 업로드(검토/보관)
        uses: actions/upload-artifact@v4
        with:
          name: final-security-report  # 최종 리포트 아티팩트 이름
          path: scan-results/final-report.md  # 업로드 파일(마크다운)
          retention-days: 30  # 보관 기간(더 길게)

      - name: Comment PR with summary  # PR이면 요약을 PR 댓글로 남김(개발자가 바로 확인 가능)
        if: github.event_name == 'pull_request'  # PR 이벤트에서만 실행
        uses: actions/github-script@v7  # GitHub API 호출용 JS 실행 액션
        with:
          script: |
            const fs = require('fs');  // 파일 읽기 모듈
            const report = fs.readFileSync('scan-results/final-report.md', 'utf8');  // 리포트 전체 읽기

            // 리포트가 너무 길면 요약만 추출
            const summary = report.split('## 📊 전체 요약')[1]?.split('##')[0] || report.substring(0, 2000);  // 특정 섹션 기준으로 요약 추출, 없으면 앞부분 일부

            await github.rest.issues.createComment({  // PR(=issue) 댓글 생성
              owner: context.repo.owner,  // 레포 소유자
              repo: context.repo.repo,  // 레포 이름
              issue_number: context.payload.pull_request.number,  // PR 번호
              body: `## 🔒 보안 분석 완료\n\n${summary}\n\n📄 전체 리포트는 Artifacts에서 확인하세요.`  // 댓글 본문
            });

  # ===================================================================
  # Job 5: SG API 티켓 발급 및 S3 업로드
  # ===================================================================
  upload-to-sg:
    name: Upload to Security Gate  # Job 표시 이름(SG=사내/외부 보안 게이트 시스템 가정)
    # 이 PR을 머지해도 되는지 판정을 받는 단계. 
    
    runs-on: ubuntu-latest  # 깃허브에서 제공하는 기본 리눅스 러너에서 실행(SG가 외부 api라면 사내 러너 아니어도 접근 가능하다고 가정) 
    needs: [analyze-and-report]  # 리포트가 만들어져야 진행. 앞에 있는 job이 끝나야 실행됨 -> 클로드가 만든 최종 리포트가 반드시 있어야함 

    steps:
      - name: Checkout code  # 아래에서 sg-upload.sh 스크립트를 쓰기 위해 레포지토리 코드를 러너로 가져옴 
        uses: actions/checkout@v4

      - name: Download final report  # 이전 Job에서 만든 최종 보안 리포트를 내려받는 단계 
        uses: actions/download-artifact@v4
        with:
          name: final-security-report  # analyze-and-report Job에서 upload한 아티팩트 이름 
          path: reports  # 저장 폴더. 러너의 ./reports 폴더에 저장. 결과 파일 경로: reports/final-report.md 
          # download-artifact는 기본적으로 아티팩트 이름으로 폴더를 하나 더 만든다. 
          # reports/ final-security-report/final-report.md 
           


      # 다운로드했을 때 이름이 final-report.md가 아니라 다른 값일 수 있으니 그거 고려해서 다시 설계하기 
      #이 단계에서 티켓을 발급하고, 그 티켓ID를 /tmp/sg-ticket-id파일에 저장했다고 가정 
 

      - name: Upload to SG via API  # SG API로 리포트 업로드하고 티켓 요청 
        env:
          SG_API_URL: ${{ secrets.SG_API_URL }}  # SG API 엔드포인트
          SG_API_TOKEN: ${{ secrets.SG_API_TOKEN }}  # SG 인증 토큰
        run: |
          chmod +x .github/scripts/sg-upload.sh  # 업로드 쉘 스크립트 실행권한?? 리눅스에서 실행 가능하도록 권한 부여(권한없으면 아래 줄에서 실행 자체가 안됨) 
          .github/scripts/sg-upload.sh \  # SG 업로드 전용 쉘 스크립트 실행 (실제 SG API 호출 로직은 전부 이 파일 안에 있음) 
            reports/final-security-report/final-report.md \  # 업로드할 리포트 파일. SG로 업로드할 최종 보안 리포트 파일 
            ${{ github.event.pull_request.number || github.event.inputs.pr_number }}  # PR 번호(수동 실행도 지원)
            # 어떤 pr의 검사인지 식별하기 위한 pr번호.
            #   - PR 자동 실행 → pull_request.number
            #   - 수동 실행 → workflow_dispatch로 입력한 pr_number
            
           
      #티켓ID 발급받는거 실패하면 unknown으로 넣는데 이건 거의 curl에서 거의 확실히 실패함
      - name: Wait for SG verdict  # SG가 pass/fail 판정 내릴 때까지 조회(폴링). 계속 물어보면서 기다리는 단계 
        id: sg-verdict  # 이 step의 출력값(outputs)을 다음 step에서 '${{ steps.sg-verdict.outputs.verrdict }}'로 쓰기 위해 붙이는 이름 
        env: # 아래 쉘 스크립트에서 쓸 환경변수(=시크릿 값)를 주입 
          SG_API_URL: ${{ secrets.SG_API_URL }}  # SG API URL. SG 서버 주소 (ex. https://sg.company.internal) 
          SG_API_TOKEN: ${{ secrets.SG_API_TOKEN }}  # SG 토큰. SG API 호출 인증 토큰(=Bearer 토큰) 
        run: |
          # 목적: SG에 "우리 리포트 업로드했으니 판정 났냐?"를 반복해서 조회(폴링)함
          # 판정이 pass/fail로 떨어지면 끝
          # 5분 동안 pass/fail이 안나오면 timeout으로 실패 처리 
          
          
          #이전 step(Upload to SG)이 티켓을 발급하고, 그 티켓ID를 /tmp/sg-ticket-id 파일에 저장했다고 가정
          TICKET_ID=$(cat /tmp/sg-ticket-id 2>/dev/null || echo "unknown")  # 업로드 스크립트가 저장한 티켓ID 읽기(없으면 unknown)
          MAX_ATTEMPTS=30  # 10초 * 30회 = 300초(5분)
          ATTEMPT=0  # 현재 시도 횟수

          echo "⏳ SG 판정 대기 중... (Ticket: $TICKET_ID)"  # 로그 출력

				  #ATTEMPT로 현재 몇번째로 물어봤는지 카운트 
				 
          while [ $ATTEMPT -lt $MAX_ATTEMPTS ]; do  # 최대 시도 횟수까지 반복
            
            # SG 서버에 이 티켓 판정 상태 알려달라고 API 호출
            # 쳐curl -s : 조용히 호출해서 결과만 받기
            # - -H "Authorization: Bearer ..." : 토큰으로 인증
            # - URL: /api/v1/tickets/{티켓ID}/verdict
		        # ✅ 응답은 JSON이라고 가정하고, jq로 그 안의 .status만 뽑아온다.
			      # 예) 응답이 {"status":"pending"} -> VERDICT="pending"
		        # 예) 응답이 {"status":"pass"}    -> VERDICT="pass"
            VERDICT=$(curl -s -H "Authorization: Bearer $SG_API_TOKEN" \  # SG verdict API 호출
              "$SG_API_URL/api/v1/tickets/$TICKET_ID/verdict" | jq -r '.status')  # JSON에서 status만 추출(jq 필요)


						# ✅ SG가 최종 결론을 내렸다면(pass 또는 fail)
            # => 기다릴 필요 없으니 루프 종료하고 이 step을 정상 종료한다.
            if [ "$VERDICT" == "pass" ] || [ "$VERDICT" == "fail" ]; then  # pass/fail이면 종료
              echo "✅ SG 판정 완료: $VERDICT"  # 완료 로그
              # ✅ GitHub Actions에서 "step output"을 남기는 공식 방법
			        #    - $GITHUB_OUTPUT 파일에 key=value 형식으로 쓰면
				      #    - 다음 step에서 `${{ steps.sg-verdict.outputs.verdict }}`로 읽을 수 있음
              echo "verdict=$VERDICT" >> $GITHUB_OUTPUT
              echo "verdict=$VERDICT" >> $GITHUB_OUTPUT  # step output으로 verdict 저장
              exit 0  # 성공 종료
            fi



						# 아직 pass/fail이 아니라면(ex. pending/running/queued 등) -> 10초 기다렸다가 다시 조회 
            echo "  ... 대기 중 ($((ATTEMPT+1))/$MAX_ATTEMPTS)"  # 아직 미완료면 진행 상황 출력
            sleep 10  # 10초 대기
            ATTEMPT=$((ATTEMPT+1))  # 카운트 증가
          done
				  # 30번(5분) 동안 물어봤는데 답 안나올 때  
          echo "❌ Timeout: SG 판정을 받지 못했습니다"  # 타임아웃 로그
          # ✅ timeout도 output으로 남겨서 다음 step이 이 상태를 인지할 수 있게 함
          echo "verdict=timeout" >> $GITHUB_OUTPUT  # timeout도 output으로 저장
          exit 1  # ✅ 실패 종료 (이 step 때문에 job이 실패로 표시됨)
          exit 1  # 실패 처리(워크플로우 실패로 보이게)




      - name: Create GitHub Check  # SG 판정 결과를 GitHub Checks로 표시(merge gate용). github의 checks를 만들어서 pr에서 merge 가능/불가를 시각적으로 표시              
        uses: actions/github-script@v7
        if: always()  # 앞 step 실패/timeout이어도 체크는 생성
        with:
          script: |
          
            # SG 판정 결과 가져오기 
            # 이전 step(id: sg-verdict)에서 $GITHUBB_OUTPUT으로 넘긴 verdict 값
            # ex.pass,fail,timeout,unknown 

            const verdict = '${{ steps.sg-verdict.outputs.verdict }}';  // 폴링 step output에서 verdict 가져오기
            
            
            #GitHub Check에서 요구하는 conclusion 값으로 변환. pass->success, 그외->failure 
            const conclusion = verdict === 'pass' ? 'success' : 'failure';  // pass면 success, 나머지는 failure 처리(unknown/timeout 포함)

						#GitHub Checks API 호출 
						
						
            await github.rest.checks.create({  // 체크 생성 API 호출
              owner: context.repo.owner,  // 레포 소유자 (자동으로 채워짐) 
              repo: context.repo.repo,  // 레포 이름(현재 레포 이름) 
              name: 'Security Gate Verdict',  // 체크 이름(PR 화면에 표시될 체크 이름) 
              
              #체크를 어느 커밋에 붙일지 결정. pr이벤트면 pr의 최신 커밋 sha, 수동 실행/푸시 이벤트면 현재 워크플로우의 sha 
              head_sha: context.payload.pull_request?.head.sha || context.sha,  // PR이면 PR head sha, 아니면 현재 sha
              
              
              status: 'completed',  // 완료 상태. 체크상태(queued / in_progress / completed 중 우리는 결과가 확정됐으니 completed) 
              conclusion: conclusion,  // 성공/실패 결론. success/failure/neutral/cancelled 등등. merge gate에서 이 값이 핵심 
              
              #pr화면에 표시될 상세 메세지 
              output: {
                title: verdict === 'pass' ? '✅ Security Gate PASSED' : '❌ Security Gate FAILED',  // 체크 타이틀( ▶ SG 통과 시 체크 제목, 패/타임아웃 시 체크 제목)
                summary: `SG 판정: **${verdict.toUpperCase()}**`,  // 한줄 요약 
                text: verdict === 'pass' //상세히 
                  ? '보안 분석 통과. Merge 가능합니다.'  // pass 안내
                  : '보안 이슈 발견. 해결 후 재시도하세요.'  // fail/timeout 안내
              }
            });


  # ===================================================================
  # Job 6: 최종 결과 요약
  # ===================================================================
  summary:
    name: Workflow Summary  # Job 표시 이름(워크플로우 요약)
    runs-on: ubuntu-latest  # 실행 러너
    needs: [upload-to-sg]  # SG 단계까지 끝나면 실행
    if: always()  # 전체 성공/실패와 관계없이 요약 생성

    steps:
      - name: Generate summary  # GitHub Actions UI에 Summary 탭으로 표 생성
        run: |
          cat << 'EOF' >> $GITHUB_STEP_SUMMARY  # GitHub Actions 기본 요약 파일에 추가
          # 🔒 PR SAST 보안 스캔 완료

          ## 📊 실행 결과

          | 단계 | 상태 |
          |------|------|
          | SonarQube | ${{ needs.sonarqube.result }} |
          | Semgrep | ${{ needs.semgrep.result }} |
          | CodeQL | ${{ needs.codeql.result }} |
          | AI Analysis | ${{ needs.analyze-and-report.result }} |
          | SG Upload | ${{ needs.upload-to-sg.result }} |

          ## 📄 다음 단계

          1. Artifacts에서 `final-security-report` 다운로드
          2. Critical/High 이슈 검토
          3. 필요 시 코드 수정 후 재푸시
          4. SG 판정 PASS 시 merge 가능

          ---

          🤖 Generated by Dark Mac & Cheese Security Pipeline
          EOF
