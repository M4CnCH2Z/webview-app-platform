<?xml version="1.0" encoding="UTF-8"?>
<!-- configuration 대신 springProfile을 지원하는 구조로 작성 -->
<configuration scan="true" scanPeriod="30 seconds">

    <!-- 환경 변수 또는 기본값 설정 -->
    <property name="LOG_PATTERN" value="%d{yyyy-MM-dd HH:mm:ss.SSS, Asia/Seoul} [%thread] %-5level %logger{36} - %msg%n"/>
    <property name="LOG_DIR" value="./logs"/>

    <!-- [공통] Console Appender -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <!-- [공통] JSON File Appender (원본) -->
    <appender name="JSON_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/shoppingmall.log</file>
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <customFields>{"app_name":"shoppingmall","environment":"local"}</customFields>
            <includeMdc>true</includeMdc>
            <includeContext>true</includeContext>
            <includeCallerData>true</includeCallerData>
            <timeZone>Asia/Seoul</timeZone>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/shoppingmall.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>100MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>3GB</totalSizeCap>
        </rollingPolicy>
    </appender>

    <!-- [공통] 비동기 JSON 파일 처리 -->
    <appender name="ASYNC_JSON_FILE" class="ch.qos.logback.classic.AsyncAppender">
        <appender-ref ref="JSON_FILE"/>
        <queueSize>512</queueSize>
        <discardingThreshold>0</discardingThreshold>
    </appender>

    <!-- [공통] Error File Appender -->
    <appender name="ERROR_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/error.log</file>
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>ERROR</level>
        </filter>
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <customFields>{"app_name":"shoppingmall","log_type":"error"}</customFields>
            <timeZone>Asia/Seoul</timeZone>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/error.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>50MB</maxFileSize>
            <maxHistory>60</maxHistory>
        </rollingPolicy>
    </appender>

    <!-- ################################################################## -->
    <!-- 환경별 설정 (핵심 변경 부분) -->
    <!-- ################################################################## -->

    <!-- [LOCAL] 프로필: Logstash 설정 자체를 포함하지 않음 -->
    <springProfile name="local">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="ASYNC_JSON_FILE"/>
            <appender-ref ref="ERROR_FILE"/>
        </root>
        <logger name="com.project.shop" level="DEBUG"/>
    </springProfile>

    <!-- [PROD/DEV] 프로필: 여기서만 Logstash 관련 정의 및 참조를 수행 -->
    <springProfile name="prod, dev, staging">
        <!-- 앱더 정의를 프로필 안으로 이동하여 로컬 실행 시 로드 방지 -->
        <appender name="LOGSTASH" class="net.logstash.logback.appender.LogstashTcpSocketAppender">
            <destination>localhost:5044</destination>
            <reconnectionDelay>10 seconds</reconnectionDelay>
            <encoder class="net.logstash.logback.encoder.LogstashEncoder">
                <customFields>{"app_name":"shoppingmall","environment":"remote"}</customFields>
                <includeMdc>true</includeMdc>
                <includeContext>true</includeContext>
                <includeCallerData>true</includeCallerData>
                <timeZone>Asia/Seoul</timeZone>
            </encoder>
            <keepAliveDuration>5 minutes</keepAliveDuration>
        </appender>

        <appender name="ASYNC_LOGSTASH" class="ch.qos.logback.classic.AsyncAppender">
            <appender-ref ref="LOGSTASH"/>
            <queueSize>1024</queueSize>
            <neverBlock>true</neverBlock>
        </appender>

        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="ASYNC_JSON_FILE"/>
            <appender-ref ref="ASYNC_LOGSTASH"/>
            <appender-ref ref="ERROR_FILE"/>
        </root>
        <logger name="com.project.shop" level="INFO"/>
    </springProfile>

    <!-- [공통 로거] -->
    <logger name="org.springframework.web" level="INFO"/>
    <logger name="org.hibernate.SQL" level="DEBUG"/>
    <logger name="org.hibernate.type.descriptor.sql.BasicBinder" level="TRACE"/>

</configuration>
