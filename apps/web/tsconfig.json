{
  "extends": "../../packages/config/tsconfig.base.json",
  "compilerOptions": {
    "module": "NodeNext",
    "jsx": "preserve",
    "moduleResolution": "NodeNext",
    "types": ["next", "next/types/global", "node"],
    "paths": {
      "@platform/bridge-contract": [
        "../../packages/bridge-contract/src"
      ],
      "@platform/api-client": [
        "../../packages/api-client/src"
      ]
    },
    "plugins": [
      {
        "name": "next"
      }
    ],
    "incremental": true,
    "isolatedModules": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
